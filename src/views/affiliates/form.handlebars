<div class="page-header">
  <h1>{{title}}</h1>
  <a href="/affiliates" class="btn">← Volver</a>
</div>

<div class="card">
  <form action="{{action}}" method="{{method}}">
    <div class="form-group">
      <label for="firstName">Nombre</label>
      <input type="text" id="firstName" name="firstName" value="{{affiliate.firstName}}" required />
    </div>

    <div class="form-group">
      <label for="lastName">Apellido</label>
      <input type="text" id="lastName" name="lastName" value="{{affiliate.lastName}}" required />
    </div>

    <div class="form-group">
      <label for="email">Correo electrónico</label>
      <input type="email" id="email" name="email" value="{{affiliate.email}}" required />
    </div>

    <div class="form-group">
      <label for="membershipType">Tipo de membresía</label>
      <select id="membershipType" name="membershipType" required>
        <option value="">Seleccionar...</option>
        <option value="silver"   {{#if affiliate.membershipType}}{{#ifeq affiliate.membershipType "silver"}}selected{{/ifeq}}{{/if}}>Silver</option>
        <option value="gold"     {{#if affiliate.membershipType}}{{#ifeq affiliate.membershipType "gold"}}selected{{/ifeq}}{{/if}}>Gold</option>
        <option value="platinum" {{#if affiliate.membershipType}}{{#ifeq affiliate.membershipType "platinum"}}selected{{/ifeq}}{{/if}}>Platinum</option>
      </select>
    </div>

    <button type="submit" class="btn btn-primary">Crear</button>
  </form>
</div>
