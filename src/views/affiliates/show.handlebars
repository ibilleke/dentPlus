<div class="page-header">
  <h1>{{affiliate.firstName}} {{affiliate.lastName}}</h1>
  <div class="header-actions">
    <a href="/affiliates/{{affiliate.id}}/edit" class="btn btn-warning">Editar</a>
    <a href="/affiliates" class="btn">← Volver</a>
  </div>
</div>

<div class="card">
  <div class="detail-row"><span class="label">Email</span><span>{{affiliate.email}}</span></div>
  <div class="detail-row">
    <span class="label">Membresía</span>
    <span class="badge badge-{{affiliate.membershipType}}">{{affiliate.membershipType}}</span>
  </div>
</div>

<div class="card">
  <h2>Calcular descuento</h2>
  <form action="/affiliates/{{affiliate.id}}/simulate" method="POST">
    <div class="form-group">
      <label for="amount">Monto ($)</label>
      <input type="number" id="amount" name="amount" min="0" step="100"
             value="{{simulation.amount}}" placeholder="Ej: 80000" required />
    </div>
    <button type="submit" class="btn btn-primary">Calcular</button>
  </form>

  {{#if simulation}}
  <div class="result">
    <p>Descuento aplicado: <strong>{{simulation.discount}}%</strong></p>
    <p class="final-price">Precio final: <strong>${{simulation.finalPrice}}</strong></p>
  </div>
  {{/if}}
</div>
