<div class="page-header">
  <h1>Afiliados registrados</h1>
</div>

{{#if affiliates.length}}
<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Email</th>
      <th>Membresía</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    {{#each affiliates}}
    <tr>
      <td>{{this.firstName}} {{this.lastName}}</td>
      <td>{{this.email}}</td>
      <td><span class="badge badge-{{this.membershipType}}">{{this.membershipType}}</span></td>
      <td class="actions">
        <a href="/affiliates/{{this.id}}" class="btn btn-sm">Ver</a>
        <a href="/affiliates/{{this.id}}/edit" class="btn btn-sm btn-warning">Editar</a>
        <form action="/affiliates/{{this.id}}?_method=DELETE" method="POST" class="inline">
          <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este afiliado?')">Eliminar</button>
        </form>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p class="empty">No hay afiliados registrados aún. <a href="/affiliates/new">Crear el primero</a>.</p>
{{/if}}
